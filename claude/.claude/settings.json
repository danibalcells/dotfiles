{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "NotebookEdit"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "editorMode": "vim"
}
